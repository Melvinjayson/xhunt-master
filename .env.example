# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Anon/public key — Supabase dashboard → Settings → API → anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# Service role key — Supabase dashboard → Settings → API → service_role (KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── xAI (Grok) ────────────────────────────────────────────────────────────────
XAI_API_KEY=xai-...

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret — Stripe dashboard → Webhooks → https://your-domain.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
# Strong random secret — openssl rand -base64 32
CRON_SECRET=replace-with-random-secret
LLM_PROVIDER=groq

# ── Firebase ──────────────────────────────────────────────────────────────────
# Firebase console → Project settings → Your apps → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=<project-id>.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=<project-id>
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=<project-id>.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<sender-id>
NEXT_PUBLIC_FIREBASE_APP_ID=1:<sender-id>:web:<hash>
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-...
# Strong random secret for HMAC session cookies — openssl rand -base64 32
SESSION_SECRET=replace-with-32-char-random-secret

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Anon/public key — Supabase dashboard → Settings → API → anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# Service role key — Supabase dashboard → Settings → API → service_role (KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── xAI (Grok) ────────────────────────────────────────────────────────────────
XAI_API_KEY=xai-...

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret — Stripe dashboard → Webhooks → https://your-domain.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
# Strong random secret — openssl rand -base64 32
CRON_SECRET=replace-with-random-secret
LLM_PROVIDER=groq

# ── Optional (Clerk legacy webhook only) ──────────────────────────────────────
# CLERK_SECRET_KEY=sk_...
# CLERK_WEBHOOK_SECRET=whsec_...

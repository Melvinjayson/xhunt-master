# ─────────────────────────────────────────────────────────────────────────────
# XHunt Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Found at: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
# Webhook secret — created in Clerk Dashboard → Webhooks → Add Endpoint
# Endpoint URL: https://your-domain.com/api/clerk/webhook
# Events to subscribe: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_...

# ── AI Providers ──────────────────────────────────────────────────────────────
# Groq (primary — used for mission generation, step adaptation, recommendations)
# https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Anthropic Claude (secondary — used for deep-think agent reasoning)
# https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# LLM routing config (optional — defaults to 'groq')
LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-70b-versatile

# ── Stripe Payments ───────────────────────────────────────────────────────────
# Found at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret — created in Stripe Dashboard → Developers → Webhooks
# Endpoint URL: https://your-domain.com/api/stripe/webhook
# Events: customer.subscription.created, customer.subscription.deleted, invoice.payment_succeeded
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the Pro subscription (monthly)
# Create at: https://dashboard.stripe.com/products
STRIPE_PRO_PRICE_ID=price_...

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://xhunt.app

# ── Cron Security ─────────────────────────────────────────────────────────────
# Used to protect /api/cron/* endpoints from unauthorized calls.
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ── Developer API (optional) ──────────────────────────────────────────────────
# Issued to developers who integrate with the XHunt API.
# XHUNT_API_KEY=xhunt_...

# ── OpenAI fallback (optional) ────────────────────────────────────────────────
# Only needed if LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# Deployment checklist:
# 1. Set all variables above in your deployment platform (Vercel → Settings → Env Vars)
# 2. Configure Stripe webhook endpoint in Stripe Dashboard
# 3. Configure Clerk webhook endpoint in Clerk Dashboard
# 4. Run Supabase migrations: supabase db push (or apply migrations/*.sql manually)
# 5. Verify Supabase RLS policies are enabled on all tables
# ─────────────────────────────────────────────────────────────────────────────
